{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pigeon FE",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "pigeon BE",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/d",
        "/c",
        "conda activate pigeon && uvicorn backend.main:app --reload --port 8000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "pigeon pool",
      "dependsOn": ["pigeon BE", "pigeon FE"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "pigeon BE tests",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/d",
        "/c",
        "conda activate pigeon && pytest -v"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "pigeon FE tests",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:e2e"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    }
  ]
}
